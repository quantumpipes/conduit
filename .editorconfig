# QP Conduit - EditorConfig
# https://editorconfig.org

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Makefile (requires tabs)
[Makefile]
indent_style = tab

# YAML
[*.{yaml,yml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Caddyfile
[Caddyfile]
indent_style = tab

# dnsmasq configuration
[*.conf]
indent_size = 2
